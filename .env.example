# Infraestrutura. Os hosts "db" e "redis" pertencem ao docker-compose.yml.
# Para execução local, use SQLite e localhost conforme o README.
# Os valores abaixo são somente para desenvolvimento local. Troque usuário e
# senha juntos com DATABASE_URL antes de qualquer implantação.
POSTGRES_DB=divulgai
POSTGRES_USER=divulgai
POSTGRES_PASSWORD=divulgai
DATABASE_URL=postgresql+psycopg://divulgai:divulgai@db:5432/divulgai
REDIS_URL=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# Segurança. Gere valores distintos; ENCRYPTION_KEY deve ser uma chave Fernet.
SECRET_KEY=
JWT_SECRET_KEY=
ENCRYPTION_KEY=
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Ambiente e chave geral para permitir ou bloquear qualquer chamada externa.
ENVIRONMENT=development
DEBUG=false
EXTERNAL_SERVICES_ENABLED=false
BASE_URL=http://localhost:8000

# Configuração global do aplicativo/webhook Meta. Tokens, IDs de contas e a
# chave do provedor de IA são cadastrados por empresa na tela Integrações.
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_GRAPH_VERSION=v22.0
AI_API_URL=https://api.openai.com/v1/responses
AI_MODEL=gpt-4.1-mini
AI_MAX_OUTPUT_TOKENS=1200

# Limites de mídia, campanhas e geração assistida.
MAX_UPLOAD_MB=15
MAX_COMPANY_UPLOAD_MB=250
DAILY_MESSAGE_LIMIT=1000
MINUTE_MESSAGE_LIMIT=30
HOURLY_MESSAGE_LIMIT=300
LARGE_CAMPAIGN_THRESHOLD=500
DAILY_AI_GENERATION_LIMIT=100
MINUTE_AI_GENERATION_LIMIT=5
